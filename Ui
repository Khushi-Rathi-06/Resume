import streamlit as st

from ui import (
    load_css,
    hero,
    idea_box,
    dashboard_cards,
    domain_card,
    target_customer_card,
    market_gap_card,
    competitor_cards,
    business_model_cards,
    risk_card,
    swot_grid,
    verdict_card
)

st.set_page_config(
    page_title="StartupGuideAI",
    page_icon="🚀",
    layout="wide"
)

load_css()

hero()

idea, analyze = idea_box()

if analyze:

    if idea.strip() == "":

        st.warning("Please enter your startup idea.")

        st.stop()

    with st.spinner("Analyzing Startup..."):

        summary = generate_summary(idea)

        domain_result = detect_domain(summary)

        domain = domain_result["domain"]

        confidence = domain_result["confidence"]

        competitor = find_similar_startups(summary)

        competitor_data = []

        for company, score, desc, industry, subindustry in zip(

            competitor["Competitors"],

            competitor["Scores"],

            competitor["Descriptions"],

            competitor["Industries"],

            competitor["Subindustries"]

        ):

            competitor_data.append({

                "name": company,

                "score": score,

                "description": desc,

                "industry": industry,

                "subindustry": subindustry

            })

        categorized = categorize_competitors(

            competitor_data,

            domain

        )

        differentiation = calculate_differentiation(

            summary,

            competitor["Descriptions"]

        )

        competition_score = differentiation["average_similarity"]

        gaps = identify_market_gap(

            summary,

            competitor["Descriptions"]

        )

        gap_analysis = explain_market_gap(

            summary,

            competitor["Competitors"],

            gaps

        )

        opportunity = calculate_opportunity(

            differentiation["score"],

            confidence,

            competition_score,

            len(gaps)

        )

        opportunity_score = float(opportunity)

        startup_score = calculate_startup_score(

            confidence,

            opportunity_score,

            100 - differentiation["score"],

            competition_score,

            differentiation["score"]

        )

        investor = calculate_investor_readiness(

            startup_score,

            opportunity_score,

            competition_score,

            differentiation["score"]

        )

        business_models = suggest_business_models(

            domain

        )

        swot = generate_swot(

            gaps,

            len(categorized["Direct"]) +
            len(categorized["Indirect"])

        )

        risk = analyse_risk(

            {

                "startup_score": startup_score

            }

        )

        verdict = generate_verdict(

            startup_score,

            competition_score,

            opportunity_score,

            gaps,

            investor["score"],

            differentiation["score"]

        )
