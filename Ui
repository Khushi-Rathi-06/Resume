def competitor_cards(categorized):

    st.markdown("## 🏆 Top Competitors")

    for category in ["Direct","Indirect","Adjacent"]:

        if len(categorized[category]) == 0:
            continue

        st.markdown(f"### {category}")

        cols = st.columns(2)

        index = 0

        for company in categorized[category][:4]:

            with cols[index % 2]:

                st.markdown(f"""

                <div class="card">

                <h4>{company['name']}</h4>

                <p><b>Similarity :</b> {company['score']:.1f}%</p>

                <p><b>Industry :</b> {company['industry']}</p>

                <p><b>Sub Industry :</b> {company['subindustry']}</p>

                <hr>

                <p>{company['description']}</p>

                </div>

                """, unsafe_allow_html=True)

            index += 1
