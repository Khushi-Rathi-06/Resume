def idea_box():

    st.markdown(
        '<div class="section-title">Describe Your Startup Idea</div>',
        unsafe_allow_html=True
    )

    idea = st.text_area(
        "",
        placeholder="""
Example:

AI powered interview preparation platform for college students
that provides mock interviews, resume analysis and personalized
learning roadmap.
        """,
        height=110,
        label_visibility="collapsed"
    )

    st.write("")

    c1, c2, c3 = st.columns([2.2, 1, 2.2])

    with c2:
        analyze = st.button(
            "Analyze Startup",
            use_container_width=True
        )

    st.write("")
    st.write("")

    return idea, analyze
