import streamlit as st

from services.startup_summary_service import generate_startup_summary
from services.domain_service import identify_domain
from services.similarity_service import find_similar_startups
from services.competitor_service import categorize_competitors
from services.differentiation_service import calculate_differentiation
from services.market_gap_service import identify_market_gap, explain_market_gap
from services.opportunity_service import generate_opportunities
from services.startup_score_service import (
    calculate_startup_score,
    analyse_risk
)
from services.investor_readiness_service import calculate_investor_readiness
from services.business_model_service import suggest_business_models
from services.swot_service import generate_swot
from services.verdict_service import generate_verdict

st.set_page_config(
    page_title="StartupGuideAI",
    page_icon="🚀",
    layout="wide"
)

st.markdown("""
<style>

.main{
    background:#0E1117;
}

.block-container{
    padding-top:2rem;
}

.stButton>button{
    width:100%;
    border-radius:10px;
    height:50px;
    font-size:18px;
    font-weight:bold;
}

.card{
    padding:18px;
    border-radius:12px;
    background:#1e293b;
    margin-bottom:15px;
}

</style>
""", unsafe_allow_html=True)

st.title("🚀 StartupGuideAI")

st.caption("AI Powered Startup Analysis Platform")

st.divider()

idea = st.text_area(
    "Describe your Startup Idea",
    placeholder="Example : AI Interview Preparation Platform for College Students",
    height=150
)

analyze = st.button("Analyze Startup")

if analyze:

    if idea.strip()=="":

        st.warning("Please enter your startup idea.")

        st.stop()

    with st.spinner("Analyzing Startup..."):

        summary = generate_startup_summary(idea)

        domain_result = identify_domain(summary)

        domain = domain_result["domain"]

        confidence = domain_result["confidence"]

        competitor = find_similar_startups(summary)

        competitor_data = []

        for company,score,desc,industry,subindustry in zip(

            competitor["Competitors"],
            competitor["Scores"],
            competitor["Descriptions"],
            competitor["Industry"],
            competitor["SubIndustry"]

        ):

            competitor_data.append({

                "name":company,
                "score":score,
                "description":desc,
                "industry":industry,
                "subindustry":subindustry

            })

        categorized = categorize_competitors(
            competitor_data,
            domain
        )

        differentiation = calculate_differentiation(
            summary,
            competitor["Descriptions"]
        )

        gaps = identify_market_gap(
            summary,
            competitor["Descriptions"]
        )

        gap_analysis = explain_market_gap(
            summary,
            competitor["Competitors"],
            gaps
        )

        opportunity = generate_opportunities(
            domain,
            gaps
        )

        opportunity_score = len(opportunity) * 13

        startup_score = calculate_startup_score(

            confidence,
            opportunity_score,
            100-differentiation["score"],
            categorized["average_similarity"],
            differentiation["score"]

        )

        investor = calculate_investor_readiness(

            startup_score,
            opportunity_score,
            categorized["average_similarity"],
            differentiation["score"]

        )

        business_models = suggest_business_models(domain)

        swot = generate_swot(
            gaps,
            len(categorized["Direct"]) + len(categorized["Indirect"])
        )

        risk = analyse_risk(
            {"startup_score":startup_score}
        )

        verdict = generate_verdict(

            startup_score,
            categorized["average_similarity"],
            opportunity_score,
            gaps

        )
