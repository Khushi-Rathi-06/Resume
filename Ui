def domain_card(domain, confidence):

    st.markdown(f"""
    <div class="card">

    <h3>🏷 Domain</h3>

    <h2 style="color:#6C63FF;margin-bottom:10px;">
    {domain}
    </h2>

    <p><b>Confidence :</b> {confidence:.2f}%</p>

    </div>
    """, unsafe_allow_html=True)


def target_customer_card(summary):

    summary = summary.lower()

    customers = []

    if "student" in summary:
        customers.append("🎓 Students")

    if "college" in summary:
        customers.append("🏫 College Students")

    if "job" in summary:
        customers.append("💼 Job Seekers")

    if "business" in summary:
        customers.append("🏢 Businesses")

    if "startup" in summary:
        customers.append("🚀 Startup Founders")

    if "company" in summary:
        customers.append("🏭 Companies")

    if len(customers) == 0:
        customers.append("👥 General Users")

    html = """

    <div class="card">

    <h3>👥 Target Customers</h3>

    <ul>

    """

    for user in customers:

        html += f"<li>{user}</li>"

    html += """

    </ul>

    </div>

    """

    st.markdown(html, unsafe_allow_html=True)


